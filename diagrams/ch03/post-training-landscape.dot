digraph post_training_landscape {
    graph [fontname="Helvetica Neue", fontsize=13, bgcolor="white", size="6.4,8", ratio=compress,
           rankdir=TB, nodesep=0.5, ranksep=0.6, pad=0.3];
    node  [fontname="Helvetica Neue", fontsize=11, shape=box,
           style="rounded,filled", penwidth=1.2, margin="0.12,0.06"];
    edge  [fontname="Helvetica Neue", fontsize=10, color="#607D8B",
           penwidth=1.0, arrowsize=0.6];

    // Start
    base [label="Pre-trained\nBase Model\n(raw next-token predictor)", fillcolor="#ECEFF1", color="#B0BEC5"];

    // SFT
    subgraph cluster_sft {
        style="rounded"; color="#00758F"; bgcolor="#E0F2F1";
        label="Stage 1: Supervised Fine-Tuning"; fontcolor="#00758F"; fontsize=10;
        
        sft_data [label="Curated\n(instruction, response)\npairs\n~10K-100K examples", fillcolor="#FFFDE7", color="#FDD835"];
        sft_train [label="SFT Training\n(loss on assistant\ntokens only)", fillcolor="#F3E5F5", color="#BA68C8"];
        sft_model [label="SFT Model\n(follows instructions\nbut not aligned)", fillcolor="#E8F5E9", color="#81C784"];
        
        sft_data -> sft_train -> sft_model;
    }

    // Preference data collection
    pref_data [label="Human Preference Data\n(prompt, chosen, rejected)\n~100K-500K comparisons", fillcolor="#FFFDE7", color="#FDD835"];

    // Branch: RLHF vs DPO
    subgraph cluster_rlhf {
        style="rounded"; color="#C4362A"; bgcolor="#FCE4EC";
        label="Path A: RLHF (Complex, Flexible)"; fontcolor="#C4362A"; fontsize=10;
        
        rm_train [label="Train Reward\nModel\n(separate model)", fillcolor="#FFF3E0", color="#FFB74D"];
        ppo [label="PPO\nOptimization\n(4 models in memory)", fillcolor="#F3E5F5", color="#BA68C8"];
    }

    subgraph cluster_dpo {
        style="rounded"; color="#2E7D32"; bgcolor="#E8F5E9";
        label="Path B: DPO (Simple, Stable)"; fontcolor="#2E7D32"; fontsize=10;
        
        dpo_train [label="Direct Policy\nOptimization\n(2 models in memory)", fillcolor="#F3E5F5", color="#BA68C8"];
    }

    // Safety
    subgraph cluster_safety {
        style="rounded"; color="#FFB74D"; bgcolor="#FFF3E0";
        label="Stage 3: Safety Training"; fontcolor="#E65100"; fontsize=10;
        
        red_team [label="Red-Team\nTesting", fillcolor="#FCE4EC", color="#E57373"];
        safety_sft [label="Safety SFT\n(refusal examples)", fillcolor="#FFF3E0", color="#FFB74D"];
        safety_rlhf [label="Safety RLHF\n(harmless preferences)", fillcolor="#FFF3E0", color="#FFB74D"];
    }

    // Final
    aligned [label="Aligned Model\n(helpful, harmless,\nhonest)", fillcolor="#E8F5E9", color="#81C784", penwidth=2.0];

    // Flow
    base -> sft_data;
    sft_model -> pref_data;
    
    pref_data -> rm_train [label="RLHF path"];
    rm_train -> ppo;
    
    pref_data -> dpo_train [label="DPO path"];
    
    ppo -> red_team;
    dpo_train -> red_team;
    
    red_team -> safety_sft -> safety_rlhf -> aligned;
}
