digraph monitoring_layers {
    bgcolor="#FAFAFA";
    pad=0.5;
    rankdir=TB;
    nodesep=0.4;
    ranksep=0.7;
    
    node [
        fontname="Helvetica Neue"
        fontsize=10
        style="filled,rounded"
        shape=box
        penwidth=1.5
    ];
    
    edge [
        color="#4A4A4A"
        penwidth=1.5
        arrowsize=0.7
    ];
    
    // Layer 1: Infrastructure
    subgraph cluster_infra {
        label="Layer 1: Infrastructure (Every Request, Real-time)";
        labeljust=l;
        fontname="Helvetica Neue Bold";
        fontsize=11;
        fontcolor="#C4362A";
        style="rounded";
        color="#C4362A";
        bgcolor="#FFF5F5";
        
        latency [label="Latency\np50/p95/p99" fillcolor="#FFCDD2" color="#C4362A"];
        tokens [label="Token\nUsage" fillcolor="#FFCDD2" color="#C4362A"];
        errors [label="API Error\nRates" fillcolor="#FFCDD2" color="#C4362A"];
        cost [label="Cost per\nRequest" fillcolor="#FFCDD2" color="#C4362A"];
    }
    
    // Layer 2: Quality
    subgraph cluster_quality {
        label="Layer 2: Quality (5–10% Sample, Async)";
        labeljust=l;
        fontname="Helvetica Neue Bold";
        fontsize=11;
        fontcolor="#E65100";
        style="rounded";
        color="#E65100";
        bgcolor="#FFF8F0";
        
        rubric [label="Rubric\nScores" fillcolor="#FFE0B2" color="#E65100"];
        schema [label="Schema\nCompliance" fillcolor="#FFE0B2" color="#E65100"];
        refusal [label="Refusal\nRate" fillcolor="#FFE0B2" color="#E65100"];
        grounded [label="Groundedness\n(RAG)" fillcolor="#FFE0B2" color="#E65100"];
    }
    
    // Layer 3: Business
    subgraph cluster_business {
        label="Layer 3: Business (Aggregated, Daily)";
        labeljust=l;
        fontname="Helvetica Neue Bold";
        fontsize=11;
        fontcolor="#2E7D32";
        style="rounded";
        color="#2E7D32";
        bgcolor="#F1F8E9";
        
        satisfaction [label="User\nSatisfaction" fillcolor="#C8E6C9" color="#2E7D32"];
        completion [label="Task\nCompletion" fillcolor="#C8E6C9" color="#2E7D32"];
        regen [label="Regeneration\nRate" fillcolor="#C8E6C9" color="#2E7D32"];
        adoption [label="Feature\nAdoption" fillcolor="#C8E6C9" color="#2E7D32"];
    }
    
    // Anomaly detection
    anomaly [
        label="Anomaly Detection Engine\n────────────\n• Score distribution shifts\n• Category-specific regression\n• Temporal patterns\n• Provider-side changes"
        shape=record
        fillcolor="#F3E5F5"
        color="#7B1FA2"
    ];
    
    // Alert
    alert [label="🚨 Alert\n& Incident" shape=octagon fillcolor="#FFF9C4" color="#F9A825"];
    
    // Connections
    latency -> anomaly [style=dashed];
    rubric -> anomaly;
    satisfaction -> anomaly [style=dashed];
    anomaly -> alert;
    
    label="Three-Layer AI Monitoring Architecture";
    labelloc=t;
    fontname="Helvetica Neue Bold";
    fontsize=16;
    fontcolor="#1A1A2E";
}
