digraph agent_skeleton {
    bgcolor="#FAFAFA";
    pad=0.5;
    rankdir=TB;
    nodesep=0.5;
    ranksep=0.7;
    
    node [
        fontname="Helvetica Neue"
        fontsize=10
        style="filled,rounded"
        shape=box
        penwidth=1.5
    ];
    
    edge [
        color="#4A4A4A"
        penwidth=1.5
        arrowsize=0.7
    ];
    
    // Core LLM
    llm [
        label="LLM Reasoning\n(20%)"
        shape=ellipse
        fillcolor="#F3E5F5"
        color="#7B1FA2"
        fontname="Helvetica Neue Bold"
        fontsize=14
    ];
    
    // Engineering infrastructure (80%)
    subgraph cluster_skeleton {
        label="Production Agent Skeleton (80% Engineering)";
        labeljust=l;
        fontname="Helvetica Neue Bold";
        fontsize=12;
        fontcolor="#1A1A2E";
        style="rounded";
        color="#00758F";
        bgcolor="#F8FCFE";
        
        traces [
            label="Structured\nReasoning Traces\n────────\nTyped, serializable\nDebugable, replayable"
            fillcolor="#E3F2FD"
            color="#1565C0"
        ];
        
        tools [
            label="Tool Execution\nFramework\n────────\nInput validation\nTimeout/retry\nPermission scoping"
            fillcolor="#E3F2FD"
            color="#1565C0"
        ];
        
        termination [
            label="Termination\nConditions\n────────\nStep limit\nCost budget\nStall detection"
            fillcolor="#E3F2FD"
            color="#1565C0"
        ];
        
        observe [
            label="Observability\n────────\nAgent traces\nCost attribution\nFailure analysis"
            fillcolor="#E3F2FD"
            color="#1565C0"
        ];
        
        hitl [
            label="Human-in-the-Loop\n────────\nApproval gates\nConfidence routing\nEscalation paths"
            fillcolor="#E3F2FD"
            color="#1565C0"
        ];
        
        state [
            label="State\nManagement\n────────\nCheckpoints\nRecovery\nPersistence"
            fillcolor="#E3F2FD"
            color="#1565C0"
        ];
    }
    
    // Connections
    llm -> traces;
    llm -> tools;
    llm -> termination;
    traces -> observe;
    tools -> observe;
    termination -> hitl;
    observe -> state;
    hitl -> state;
    
    label="Production Agent Skeleton: 20% LLM, 80% Engineering";
    labelloc=t;
    fontname="Helvetica Neue Bold";
    fontsize=16;
    fontcolor="#1A1A2E";
}
