digraph circuit_breaker {
    graph [fontname="Helvetica Neue", fontsize=13, bgcolor="white", size="6.4,4.5!", ratio=fill,
           rankdir=LR, nodesep=0.4, ranksep=0.6, pad=0.3];
    node  [fontname="Helvetica Neue", fontsize=10, shape=box,
           style="rounded,filled", penwidth=1.2, margin="0.12,0.06"];
    edge  [fontname="Helvetica Neue", fontsize=9, color="#607D8B",
           penwidth=1.0, arrowsize=0.7];

    // Agent loop
    agent [label="Agent\nReasoning\nLoop", fillcolor="#E3F2FD", color="#42A5F5", fontsize=11, penwidth=2];

    // Monitor
    subgraph cluster_monitor {
        style="rounded"; color="#7B1FA2"; bgcolor="#F3E5F5"; penwidth=2;
        label="Semantic Velocity Monitor"; fontcolor="#7B1FA2"; fontsize=11;
        
        embed [label="Embed\naction[N]", fillcolor="white", color="#AB47BC"];
        compare [label="cosine_sim(\naction[N],\naction[N-1]\n)", fillcolor="white", color="#AB47BC"];
        budget [label="Budget\nCheck\n($cost, steps)", fillcolor="white", color="#AB47BC"];
    }

    // States
    subgraph cluster_states {
        style="rounded"; color="#2E7D32"; bgcolor="#E8F5E9"; penwidth=2;
        label="Breaker States"; fontcolor="#2E7D32"; fontsize=11;
        
        closed [label="CLOSED\n(normal operation)", fillcolor="#C8E6C9", color="#66BB6A", penwidth=2];
        open [label="OPEN\n(autonomy\nsuspended)", fillcolor="#FFCDD2", color="#E57373", penwidth=2];
        halfopen [label="HALF-OPEN\n(probe with\nsingle action)", fillcolor="#FFF9C4", color="#FBC02D"];
    }

    hitl [label="Human-in-\nthe-Loop\nEscalation", fillcolor="#FFFDE7", color="#FBC02D", fontsize=11, penwidth=2];
    deterministic [label="Deterministic\nFallback\nPath", fillcolor="#ECEFF1", color="#90A4AE"];

    // Flow
    agent -> embed [label="every action"];
    embed -> compare;
    compare -> budget;
    budget -> closed [label="healthy", color="#2E7D32"];
    budget -> open [label="sim > 0.95\n× 3 loops\nOR budget\nexhausted", color="#C4362A", penwidth=1.3];
    open -> hitl;
    open -> deterministic;
    open -> halfopen [label="cooldown\ntimer", style=dashed];
    halfopen -> closed [label="probe\nsucceeds", color="#2E7D32", style=dashed];
    halfopen -> open [label="probe\nfails", color="#C4362A", style=dashed];
}
